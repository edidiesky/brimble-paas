{
  "name": "brimble-deploy",
  "version": "1.0.0",
  "description": "A miniature PaaS pipeline that kind of build, run, and route containerised apps via Railpack, Docker, and Caddy.",
  "main": "dist/server.js",
  "scripts": {
    "build": "npx tsc",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "start": "node dist/server.js",
    "test": "jest",
    "test:unit": "jest --testPathPattern=__tests__/unit",
    "test:integration": "jest --testPathPattern=__tests__/integration",
    "test:coverage": "jest --coverage",
    "test:load": "k6 run k6/deployment.load.ts",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "amqplib": "^0.10.3",
    "axios": "^1.6.7",
    "cors": "^2.8.6",
    "dockerode": "^4.0.10",
    "express": "^4.18.2",
    "express-async-handler": "^1.2.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "joi": "^17.12.1",
    "mongoose": "^8.1.3",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "pg": "^8.20.0",
    "prom-client": "^15.1.3",
    "uuid": "^11.1.0",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.4",
    "@types/cors": "^2.8.19",
    "@types/dockerode": "^3.3.23",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.17",
    "@types/supertest": "^6.0.3",
    "ioredis-mock": "^8.9.0",
    "jest": "^29.7.0",
    "@types/uuid": "^10.0.0",
    "mongodb-memory-server": "^9.5.0",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
